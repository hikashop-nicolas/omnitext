{
  "name": "omnitext",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-only, format-agnostic, extensible text editor",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@milkdown/crepe": "^7.21.2",
    "ajv": "^8.20.0",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "docxedit": "github:hikashop-nicolas/docxedit",
    "dompurify": "^3.4.11",
    "fast-xml-parser": "^5.9.3",
    "fflate": "^0.8.3",
    "ini": "^6.0.0",
    "js-yaml": "^4.2.0",
    "json5": "^2.2.3",
    "latex.js": "^0.12.6",
    "marked": "^18.0.5",
    "odtedit": "github:hikashop-nicolas/odtedit",
    "pdf-lib": "^1.17.1",
    "pdfedit": "github:hikashop-nicolas/pdfedit",
    "pdfjs-dist": "^6.0.227",
    "quill": "^2.0.3",
    "sheetedit": "github:hikashop-nicolas/sheetedit",
    "toml": "^4.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "license": "MIT"
}
